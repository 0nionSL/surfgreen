{
  "expo": {
    "name": "SurfGreen",
    "slug": "surfgreen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "surfgreen",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B132B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.surfgreen.app",
      "config": {
        "googleMapsApiKey": "AIzaSyC2Gx1s7-ZZW4YI8unO4lYzC3iK5P8I4jE"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SurfGreen использует ваше местоположение для поиска ближайших спотов",
        "NSLocationAlwaysUsageDescription": "SurfGreen использует ваше местоположение для поиска ближайших спотов"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B132B"
      },
      "package": "com.surfgreen.app",
      "edgeToEdgeEnabled": true,
      "backgroundColor": "#0B132B",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Разрешите SurfGreen использовать ваше местоположение для поиска ближайших спотов"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6104b2d8-b61a-4870-947f-ac0e8609727b"
      }
    }
  }
}
